{
  "name": "@monei-js/node-sdk",
  "version": "2.0.2",
  "description": "Node.js SDK for MONEI Digital Payment Gateway",
  "keywords": [
    "api",
    "credit cards",
    "monei",
    "payment gateway",
    "payment processing"
  ],
  "homepage": "https://monei.com",
  "license": "MIT",
  "author": "MONEI <support@monei.com> (https://monei.com)",
  "contributors": [
    "Dmitriy Nevzorov <dn@monei.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MONEI/monei-node-sdk"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "generate": "openapi-generator-cli generate --generator-key typescript-axios",
    "generate:local": "openapi-generator-cli generate --generator-key typescript-axios-local",
    "compile": "vp pack",
    "dev": "vp pack --watch",
    "build": "pnpm generate && pnpm replace && pnpm format && pnpm compile",
    "build:local": "pnpm generate:local && pnpm replace && pnpm format && pnpm compile",
    "replace": "node scripts/replace.js",
    "release": "release-it",
    "prepack": "pnpm build",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "commitlint": "commitlint --edit",
    "typecheck": "tsc --noEmit",
    "lint-staged": "vp staged",
    "format": "vp fmt \"**/*.ts\"",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "prepare": "vp config"
  },
  "dependencies": {
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@release-it/conventional-changelog": "11.0.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "axios-mock-adapter": "^2.1.0",
    "release-it": "^20.0.1",
    "replace-in-file": "^8.4.0",
    "typescript": "^6.0.3",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@11.3.0"
}
